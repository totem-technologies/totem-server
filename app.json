{
  "name": "Totem Web Server",
  "healthchecks": {
    "web": [
      {
        "type": "startup",
        "name": "web check",
        "path": "/dev/healthcheck/",
        "contents": "ITSALLOK",
        "attempts": 5
      },
      {
        "type": "liveness",
        "name": "web liveness",
        "path": "/dev/healthcheck/",
        "content": "ITSALLOK",
        "timeout": 10,
        "wait": 10,
        "attempts": 3,
        "initialDelay": 30
      }
    ]
  },
  "cron": [
    {
      "command": "./manage.py totem_tasks",
      "schedule": "*/10 * * * *"
    },
    {
      "command": "./manage.py clearsessions",
      "schedule": "@daily"
    }
  ],
  "scripts": {
    "dokku": {
      "predeploy": "/predeploy"
    }
  }
}

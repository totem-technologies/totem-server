{
  "name": "theme",
  "version": "3.5.0",
  "description": "",
  "type": "module",
  "scripts": {
    "build:atcb": "bun build node_modules/add-to-calendar-button/dist/atcb-no-pro.js --drop=console --minify --outfile=totem/static/js/atcb.min.js && perl -pi -e s,add-to-calendar-pro.com,totem.org,g totem/static/js/atcb.min.js",
    "build:js": "bun run build.ts",
    "build:tailwind": "NODE_ENV=production bun run tw -- --minify",
    "build": "concurrently \"bun run build:tailwind\" \"bun run build:js\"",
    "dev": "concurrently --kill-others-on-fail \"bun run dev:js\" \"bun run dev:tailwind\" \"bun run build:atcb\"",
    "livereload": "livereload ./totem/ -e 'html,css,js,py,mjml' --wait 200",
    "openapi-ts": "openapi-ts",
    "typecheck": "bunx @typescript/native-preview --noEmit --skipLibCheck",
    "start": "bun run dev",
    "tw": "tailwindcss -i ./assets/css/styles.css -o ./totem/static/js/bundles/styles.css",
    "dev:js": "bun run build.ts -- dev",
    "dev:tailwind": "NODE_ENV=development bun run tw",
    "test": "vitest",
    "test:ci": "bun run typecheck && vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "engines": {
    "bun": "1.3.x"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@eslint/js": "^9.39.4",
    "@hey-api/openapi-ts": "^0.99.0",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/js-cookie": "^3.0.6",
    "bun-plugin-solid": "^1.0.0",
    "concurrently": "^10.0.3",
    "daisyui": "^5.5.23",
    "eslint": "^9.39.4",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "jsdom": "^29.1.1",
    "livereload": "^0.10.3",
    "prettier": "^3.8.4",
    "prettier-plugin-jinja-template": "^2.2.0",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite-plugin-solid": "^2.11.12",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@leeoniya/ufuzzy": "^1.0.19",
    "@rnwonder/solid-date-picker": "^1.5.0",
    "@solid-primitives/intersection-observer": "^2.2.4",
    "@solid-primitives/keyboard": "^1.3.5",
    "@solid-primitives/media": "^2.3.5",
    "@solid-primitives/refs": "^1.1.3",
    "@tanstack/solid-query": "^5.101.0",
    "@totem.org/solid-boring-avatars": "^0.0.2",
    "@zootools/email-spell-checker": "^1.12.0",
    "add-to-calendar-button": "^2.14.0",
    "js-cookie": "^3.0.8",
    "solid-element": "^1.9.1",
    "solid-icons": "^1.2.0",
    "solid-js": "^1.9.13",
    "tippy.js": "^6.3.7"
  }
}

{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "semi": false,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "bracketSameLine": true,
  "sortTailwindcss": true,
  "ignorePatterns": [
    "assets/js/client/**",
    "totem/static/js/bundles/**",
    "**/*.min.*"
  ]
}
